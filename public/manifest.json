{
  "manifest_version": 3,
  "name": "Mermaid Preview for Google Chat",
  "version": "1.1.1",
  "description": "Render Mermaid code blocks inline in Google Chat.",
  "minimum_chrome_version": "110",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.google.com/*",
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
