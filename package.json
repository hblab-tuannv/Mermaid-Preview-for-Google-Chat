{
  "name": "mermaid-preview-google-chat",
  "version": "1.3.0",
  "description": "Chrome extension (MV3) that renders Mermaid code blocks inline in Google Chat.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:content": "BUILD_TARGET=content vite build",
    "build:background": "BUILD_TARGET=background vite build",
    "copy:manifest": "node -e \"const fs=require('fs');fs.mkdirSync('dist',{recursive:true});fs.copyFileSync('public/manifest.json','dist/manifest.json')\"",
    "build": "npm run clean && npm run build:content && npm run build:background && npm run copy:manifest",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
